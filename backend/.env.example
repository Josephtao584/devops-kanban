# DevOps Kanban Backend Configuration

# Database URL (optional, uses SQLite in DATA_PATH if not set)
# For PostgreSQL: postgresql+asyncpg://user:password@localhost:5432/dbname
DATABASE_URL=sqlite+aiosqlite:///./data/kanban.db

# Data storage path
DATA_PATH=./data

# Server configuration
HOST=0.0.0.0
PORT=8000

# CORS origins (comma-separated or JSON array)
CORS_ORIGINS=["http://localhost:5173","http://localhost:3000","http://127.0.0.1:5173","http://127.0.0.1:3000"]

# Application settings
APP_NAME="DevOps Kanban API"
DEBUG=true
