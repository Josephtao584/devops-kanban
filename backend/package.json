{
  "name": "devops-kanban-backend",
  "version": "0.1.0",
  "description": "DevOps Kanban Backend API - Node.js Fastify",
  "type": "module",
  "main": "dist/src/main.js",
  "engines": {
    "node": ">=22 <23"
  },
  "scripts": {
    "dev": "tsx watch src/main.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/src/main.js",
    "test": "node --import tsx --test test/**/*.test.ts",
    "typecheck": "tsc --noEmit -p tsconfig.json"
  },
  "keywords": [
    "kanban",
    "devops",
    "fastify",
    "api"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@fastify/cors": "^9.0.1",
    "@fastify/websocket": "^8.3.1",
    "@mastra/core": "^1.14.0",
    "@mastra/libsql": "^1.7.1",
    "adm-zip": "^0.5.16",
    "cross-spawn": "^7.0.6",
    "dotenv": "^16.4.5",
    "fastify": "^4.26.2",
    "iconv-lite": "^0.7.2",
    "pino": "^8.19.0",
    "pino-pretty": "^11.0.0",
    "uuid": "^9.0.1",
    "ws": "^8.16.0",
    "yaml": "^2.8.2",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@types/adm-zip": "^0.5.8",
    "@types/node": "^22.15.30",
    "tsx": "^4.21.0",
    "typescript": "^5.8.3"
  }
}
